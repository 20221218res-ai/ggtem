# GGtem environment template
#
# Copy this file to .env.local for local development.
# Do not commit real .env, .env.local, or .env.production files.

# Database
# Local example:
# DATABASE_URL="postgresql://ggitem:ggitem_password@localhost:5432/ggitem?schema=public"
#
# Production example:
# DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&schema=public"
DATABASE_URL=""

# Optional direct Supabase PostgreSQL URL.
# Use this for local migrations or external workers if the pooled URL is not appropriate.
# The current Prisma config only requires DATABASE_URL.
DIRECT_URL=""

# Supabase project API keys
# The current app uses Prisma/Postgres directly and does not require Supabase JS keys.
# Keep service_role server-only. Never prefix it with NEXT_PUBLIC_.
SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# Durable image uploads
# Use "supabase" in production and create a public Supabase Storage bucket.
# If unset, local development falls back to public/uploads.
GGITEM_UPLOAD_STORAGE=""
GGITEM_UPLOAD_BUCKET="ggtem-uploads"

# App runtime
GGITEM_ORDER_STORAGE="prisma"
# Local HTTP development can use false. Production HTTPS must set this to true.
GGITEM_SECURE_SESSION_COOKIE="false"
# Demo accounts/tools are ignored in production by code, but keep these false everywhere except local demos.
GGITEM_ENABLE_DEMO_ACCOUNTS="false"
GGITEM_ENABLE_DEMO_TOOLS="false"
# Required for encrypted account-trade credential delivery.
# Use a long random secret or a 64-character hex key. Server-only, never expose to browser.
GGITEM_ACCOUNT_CREDENTIAL_SECRET=""

# Domains and routing
GGITEM_BASE_URL="http://localhost:3000"
ADMIN_HOSTS="admin.localhost:3000,topofword.com,www.topofword.com"
ADMIN_BASE_URL="http://admin.localhost:3000"
NEXT_PUBLIC_ADMIN_BASE_URL="http://admin.localhost:3000"

# Vercel Cron
CRON_SECRET=""
BUY_REQUEST_EXPIRE_BATCH_LIMIT="50"
ORDER_AUTO_CONFIRM_BATCH_LIMIT="30"

# Transactional email
# Resend is used for signup verification and password reset mail.
# Production should set GGITEM_EMAIL_REQUIRED="true" and GGITEM_EXPOSE_AUTH_DEBUG_LINKS="false".
RESEND_API_KEY=""
GGITEM_EMAIL_FROM="GGtem <no-reply@ggtem.com>"
GGITEM_EMAIL_REQUIRED="false"
GGITEM_EXPOSE_AUTH_DEBUG_LINKS="false"

# Production security quick values
# GGITEM_SECURE_SESSION_COOKIE="true"
# GGITEM_EMAIL_REQUIRED="true"
# GGITEM_EXPOSE_AUTH_DEBUG_LINKS="false"
# GGITEM_ENABLE_DEMO_ACCOUNTS="false"
# GGITEM_ENABLE_DEMO_TOOLS="false"

# Admin Telegram alerts
# Used for deposit/withdrawal/dispute operations. Server-only.
TELEGRAM_BOT_TOKEN=""
TELEGRAM_ADMIN_CHAT_ID=""
# Optional comma-separated list. If both are set, messages are sent to all ids.
TELEGRAM_ADMIN_CHAT_IDS=""

# PWA web push notifications
# Generate once with: npx web-push generate-vapid-keys
# Public key is sent to the browser for push subscription. Private key stays server-only.
GGITEM_WEB_PUSH_PUBLIC_KEY=""
GGITEM_WEB_PUSH_PRIVATE_KEY=""
GGITEM_WEB_PUSH_SUBJECT="mailto:no-reply@ggtem.com"

# Optional worker settings for Render or other background runners
WITHDRAWAL_BATCH_LIMIT="20"
WITHDRAWAL_QUEUE_AGE_MINUTES="10"
